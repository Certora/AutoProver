# Pipeline-generated deliverables/diagnostics (written by a run; not source).
/certora/
/.certora_internal/

# Build outputs (cargo-build-sbf / crucible).
/target/
Cargo.lock
crashes/
# Fuzzing artifacts (crucible run: corpus + explore-mode ./corpus, ./output).
/corpus/
/output/
# The fuzz harness is generated by the gate/backend (its Cargo.toml pins a
# machine-resolved crucible checkout path); not committed.
/fuzz/
# Ephemeral per-run sandbox scratch created in the workdir by the command sandbox
# (docs/command-sandbox.md §3): a private CARGO_HOME + linker TMPDIR.
/.sandbox_cargo/
/.sandbox_tmp/

